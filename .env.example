# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=vela
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=vela
# Used by backend (inside docker network host is "db")
DATABASE_URL=postgresql://vela:change_me_in_production@db:5432/vela?schema=public

# ─── Backend ───────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─── Auth / RBAC ───────────────────────────────────────────
# Long random string — sign JWTs. CHANGE in production.
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES=7d
# Public URL of the frontend (used in email links).
APP_URL=http://localhost:3000
# First Super Admin — created/updated automatically on backend boot.
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change_me_strong

# ─── Email (optional) ──────────────────────────────────────
# If unset, verification/reset links are logged to the backend console.
RESEND_API_KEY=
EMAIL_FROM=Vela <onboarding@resend.dev>

# ─── File storage (optional, S3-compatible: Cloudflare R2 / S3 / B2) ──
# If these are set, uploads go to the bucket; otherwise to local disk.
S3_ENDPOINT=                 # R2: https://<account_id>.r2.cloudflarestorage.com
S3_REGION=auto               # R2 uses "auto"
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=               # public base, e.g. https://pub-xxxx.r2.dev or your CDN domain

# ─── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Google Maps JS API key. If empty, the map renders a graceful fallback.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Auth.js (NextAuth) — optional, fill to enable login ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_long_random_string
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ─── External integration keys (optional, off by default) ──
# Leave blank to keep adapters in "not-configured" mode (no fake data).
BOOKING_API_KEY=
AGODA_API_KEY=
TRIPCOM_API_KEY=
SKYSCANNER_API_KEY=
TWELVEGO_API_KEY=
YANDEX_TRAVEL_API_KEY=
EXPEDIA_API_KEY=
