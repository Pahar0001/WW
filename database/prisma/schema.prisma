// Vela — domain model.
// Design principle: every externally-sourced value carries provenance
// (source, sourceUrl, dataStatus, trustLevel, fetchedAt). Nothing is invented.

generator client {
  provider      = "prisma-client-js"
  // Debian (node:20-slim) ships OpenSSL 3 — pin the engine so it isn't guessed.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Provenance ───────────────────────────
// Embedded as scalar fields on records that hold external data.
enum DataStatus {
  VERIFIED  // confirmed against an official / primary source
  ESTIMATED // derived/approximate, explicitly flagged in UI
  PENDING   // unknown — surfaced as "data pending", never guessed
}

enum Pace {
  CALM        // "Спокойная"
  BALANCED    // "Сбалансированная"
  ACTIVE      // "Активная"
}

enum TripStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum TripVisibility {
  PUBLIC   // visible to everyone
  PRIVATE  // only ADMIN/SUPER_ADMIN and trip members
}

enum TransportMode {
  WALK
  HIGH_SPEED_RAIL
  TRAIN
  FLIGHT
  CAR
  BUS
  CABLE_CAR
  FERRY
}

enum BudgetCategory {
  FLIGHTS
  HOTELS
  TRANSPORT
  FOOD
  ACTIVITIES
  RESERVE
}

// ─────────────────────────── Geography ───────────────────────────
model Country {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  nameLocal   String?
  isoCode     String?  @unique
  summary     String?
  heroImage   String?
  // Seasonality heatmap is stored per-month, see SeasonInsight.
  trips       Trip[]
  regions     Region[]
  seasons     SeasonInsight[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Region {
  id        String   @id @default(cuid())
  countryId String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  slug      String
  name      String
  summary   String?
  cities    City[]
  @@unique([countryId, slug])
}

model City {
  id        String   @id @default(cuid())
  regionId  String
  region    Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  slug      String
  name      String
  nameLocal String?
  lat       Float?
  lng       Float?
  summary   String?
  places    Place[]
  @@unique([regionId, slug])
}

model Place {
  id          String   @id @default(cuid())
  cityId      String
  city        City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  slug        String
  name        String
  nameLocal   String?
  kind        String?  // e.g. "national-park", "old-town", "viewpoint"
  lat         Float?
  lng         Float?
  description String?
  photoUrl    String?         // primary image
  photos      String[] @default([]) // gallery (additional images)
  // Practical guide fields (editorial — no fabricated numbers).
  howToGet    String?         // как добраться
  tips        String?         // на что обратить внимание
  nearby      String?         // что есть в округе
  // provenance
  source      String?
  sourceUrl   String?
  dataStatus  DataStatus @default(PENDING)
  trustLevel  Int        @default(3)
  fetchedAt   DateTime?
  dayPlaces   DayPlace[]
  @@unique([cityId, slug])
}

// Curated, real accommodation. Links are admin-provided (no scraping); prices are
// only shown if explicitly entered, never invented (see Real Data Policy).
model Hotel {
  id         String   @id @default(cuid())
  tripId     String
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  cityLabel  String?  // which city this hotel is in
  name       String
  address    String?
  lat        Float?
  lng        Float?
  checkIn    DateTime?
  checkOut   DateTime?
  url        String?  // booking / official link
  area       String?  // district / near what
  priceNote  String?  // free-form, e.g. "от 6 000 ₽/ночь" — only if user enters it
  notes      String?
  photoUrl   String?  // primary photo
  photos     String[] @default([])
  rating     Float?
  source     String?
  dataStatus DataStatus @default(PENDING)
  createdAt  DateTime @default(now())
}

// ─────────────────────────── Trips & routes ───────────────────────────
model Trip {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  subtitle    String?
  countryId   String
  country     Country    @relation(fields: [countryId], references: [id])
  status      TripStatus @default(DRAFT)
  visibility  TripVisibility @default(PUBLIC)
  durationDays Int
  // intended travel window, free-text + optional dates (no fabricated prices here)
  seasonLabel String?    // e.g. "March–April 2027"
  startWindow DateTime?
  endWindow   DateTime?
  heroImage   String?
  summary     String?
  // Long-form editorial description shown on the trip page.
  longDescription String?
  // Headline bullet points (e.g. "Горы Аватара", "Древние города").
  highlights  String[] @default([])
  // Best time to go, visa note, etc. — free-form editorial fields.
  bestTime    String?
  visaNote    String?
  // Editor-facing budget envelope (a stated target, not a computed price)
  budgetMinRub Int?
  budgetMaxRub Int?
  variants    RouteVariant[]
  scores      TripScore?
  opinions    TripOpinion[]
  hotels      Hotel[]
  members     TripMember[]
  tickets     Ticket[]
  documents   TripDocument[]
  events      CalendarEvent[]
  chatMessages ChatMessage[]
  albums      Album[]
  memories    Memory[]
  expenses    Expense[]
  reposts     Repost[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// A shared expense in a trip: someone paid for a group of participants who
// split it equally. Used by the in-trip "who owes whom" calculator. Amount is
// stored in minor currency units (kopecks) to keep settlement math exact.
model Expense {
  id           String   @id @default(cuid())
  tripId       String
  trip         Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  paidById     String                  // userId who actually paid
  paidBy       User     @relation("ExpensePayer", fields: [paidById], references: [id], onDelete: Cascade)
  description  String
  amount       Int                     // minor units (kopecks)
  currency     String   @default("RUB")
  date         DateTime                 // calendar day the expense belongs to
  participants String[] @default([])   // userIds who share this expense
  shares       Int[]    @default([])   // weight per participant (aligned to participants); empty/equal = equal split
  createdById  String?                 // who logged it (audit)
  createdAt    DateTime @default(now())
  @@index([tripId])
}

// A Trip has up to three variants: CALM / BALANCED / ACTIVE.
model RouteVariant {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  pace      Pace
  title     String?
  summary   String?
  days      Day[]
  budget    BudgetBreakdown?
  @@unique([tripId, pace])
}

model Day {
  id          String   @id @default(cuid())
  variantId   String
  variant     RouteVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  dayNumber   Int
  title       String?
  baseCity    String?  // human-readable city the day is based in
  notes       String?
  // load index 0..100, computed by the scoring engine (ESTIMATED by definition)
  loadIndex   Int?
  places      DayPlace[]
  legs        TransportLeg[]
  @@unique([variantId, dayNumber])
}

// Join of a Day and a Place, with ordering + dwell time.
model DayPlace {
  id          String   @id @default(cuid())
  dayId       String
  day         Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  placeId     String
  place       Place    @relation(fields: [placeId], references: [id])
  order       Int
  dwellMin    Int?     // minutes spent; provenance via place
  note        String?
  @@unique([dayId, order])
}

// A movement between two points on a given day.
model TransportLeg {
  id          String   @id @default(cuid())
  dayId       String
  day         Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  order       Int
  mode        TransportMode
  fromLabel   String
  toLabel     String
  distanceKm  Float?
  durationMin Int?
  // provenance — distances/times must be sourced, never invented
  source      String?
  sourceUrl   String?
  dataStatus  DataStatus @default(PENDING)
  trustLevel  Int        @default(3)
  fetchedAt   DateTime?
  @@unique([dayId, order])
}

// ─────────────────────────── Budget ───────────────────────────
model BudgetBreakdown {
  id        String   @id @default(cuid())
  variantId String   @unique
  variant   RouteVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  currency  String   @default("RUB")
  lines     BudgetLine[]
  updatedAt DateTime @updatedAt
}

model BudgetLine {
  id          String   @id @default(cuid())
  breakdownId String
  breakdown   BudgetBreakdown @relation(fields: [breakdownId], references: [id], onDelete: Cascade)
  category    BudgetCategory
  amount      Int?     // null => data pending
  label       String?
  // provenance
  source      String?
  sourceUrl   String?
  dataStatus  DataStatus @default(PENDING)
  trustLevel  Int        @default(3)
  fetchedAt   DateTime?
  @@unique([breakdownId, category])
}

// ─────────────────────────── Scoring & opinions ───────────────────────────
model TripScore {
  id          String   @id @default(cuid())
  tripId      String   @unique
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  comfort     Int      // 0..100
  beauty      Int
  history     Int
  load        Int      // higher = more tiring
  valueRatio  Int      // price/quality
  uniqueness  Int
  nature      Int
  overall     Int      // computed weighted average
  updatedAt   DateTime @updatedAt
}

// Multi-persona honest review (traveler, blogger, investor, competitor, skeptic, guide).
model TripOpinion {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  persona   String   // "skeptic", "guide", ...
  verdict   String   // honest, may be negative
  rating    Int?     // 0..100 optional
  createdAt DateTime @default(now())
}

// ─────────────────────────── Seasonality ───────────────────────────
model SeasonInsight {
  id          String   @id @default(cuid())
  countryId   String
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  month       Int      // 1..12
  weatherNote String?
  priceIndex  Int?     // 0..100 relative, ESTIMATED/PENDING only
  crowdIndex  Int?     // 0..100 relative
  recommended Boolean  @default(false)
  // provenance
  source      String?
  sourceUrl   String?
  dataStatus  DataStatus @default(PENDING)
  trustLevel  Int        @default(3)
  fetchedAt   DateTime?
  @@unique([countryId, month])
}

// ─────────────────────────── Users & saved trips ───────────────────────────
// ─────────────────────────── Trip planning (Phase 1) ───────────────────────────
enum TicketKind {
  FLIGHT
  TRAIN
  BUS
  FERRY
  OTHER
}

enum CalendarEventType {
  FLIGHT
  HOTEL_CHECKIN
  HOTEL_CHECKOUT
  EXCURSION
  MEETING
  REMINDER
  OTHER
}

enum ReminderChannel {
  EMAIL
  PUSH
  NONE
}

// Transport ticket (flight / rail / bus / ferry) with optional PDF.
model Ticket {
  id           String     @id @default(cuid())
  tripId       String
  trip         Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  kind         TicketKind @default(FLIGHT)
  carrier      String?    // перевозчик
  code         String?    // номер рейса / поезда
  fromLocation String?
  toLocation   String?
  departAt     DateTime?
  arriveAt     DateTime?
  seat         String?
  notes        String?
  fileUrl      String?    // uploaded PDF
  createdById  String?
  createdBy    User?      @relation("UserTickets", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
}

// Trip document (PDF / image) — visa, insurance, booking, etc.
model TripDocument {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title       String
  category    String?
  fileUrl     String
  mime        String?
  createdById String?
  createdBy   User?    @relation("UserDocuments", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

// Calendar event with optional reminders.
model CalendarEvent {
  id          String            @id @default(cuid())
  tripId      String
  trip        Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  type        CalendarEventType @default(OTHER)
  title       String
  startAt     DateTime
  endAt       DateTime?
  location    String?
  notes       String?
  createdById String?
  createdBy   User?             @relation("UserEvents", fields: [createdById], references: [id], onDelete: SetNull)
  reminders   Reminder[]
  createdAt   DateTime          @default(now())
}

// A reminder fires `offsetMinutes` before the event. Architecture is channel-aware
// for future email/push; the worker currently sends EMAIL (or logs it).
model Reminder {
  id            String          @id @default(cuid())
  eventId       String
  event         CalendarEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  offsetMinutes Int             // 60=1h, 1440=1d, 10080=1w, or custom
  channel       ReminderChannel @default(EMAIL)
  sent          Boolean         @default(false)
  sentAt        DateTime?
  createdAt     DateTime        @default(now())
}

// ─────────────────────────── Memories (Phase 3) ───────────────────────────
model Album {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title       String
  coverUrl    String?
  createdById String?
  createdBy   User?    @relation("UserAlbums", fields: [createdById], references: [id], onDelete: SetNull)
  photos      Photo[]
  createdAt   DateTime @default(now())
}

model Photo {
  id          String   @id @default(cuid())
  albumId     String
  album       Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  url         String
  caption     String?
  takenAt     DateTime?
  createdById String?
  createdAt   DateTime @default(now())
}

// Travel-diary entry.
model Memory {
  id          String   @id @default(cuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title       String
  text        String
  date        DateTime
  location    String?
  photos      String[] @default([])
  createdById String?
  createdBy   User?    @relation("UserMemories", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

// Support chat: a 1:1 thread between a user and the platform's super admins.
// The thread is keyed by the requesting user (`userId`); `fromSupport` marks
// replies written by staff. HTTP + polling, like the trip chat.
model SupportMessage {
  id          String   @id @default(cuid())
  userId      String                   // thread owner (the user asking for help)
  user        User     @relation("SupportThread", fields: [userId], references: [id], onDelete: Cascade)
  authorId    String?                  // who wrote it (user or admin); null if author removed
  fromSupport Boolean  @default(false) // true = written by staff
  text        String
  createdAt   DateTime @default(now())
  @@index([userId, createdAt])
}

// Group chat message within a trip (HTTP + polling, stored in Postgres).
model ChatMessage {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserMessages", fields: [userId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())
  @@index([tripId, createdAt])
}

// ─────────────────────────── Auth & RBAC ───────────────────────────
enum UserRole {
  SUPER_ADMIN
  ADMIN
  ORGANIZER
  MEMBER
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum TripMemberRole {
  ORGANIZER
  MEMBER
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String?
  image               String?
  bio                 String?
  passwordHash        String?
  role                UserRole   @default(MEMBER)
  status              UserStatus @default(ACTIVE)
  emailVerified       Boolean    @default(false)
  emailVerifyToken    String?
  emailVerifyExpiry   DateTime?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  // When the user accepted the Terms of Use (пользовательское соглашение).
  // Null = not yet accepted → the blocking terms modal is shown after email verify.
  termsAcceptedAt     DateTime?
  saved               SavedTrip[]
  memberships         TripMember[]
  auditLogs           AuditLog[]
  tickets             Ticket[]       @relation("UserTickets")
  documents           TripDocument[] @relation("UserDocuments")
  events              CalendarEvent[] @relation("UserEvents")
  messages            ChatMessage[]  @relation("UserMessages")
  albums              Album[]        @relation("UserAlbums")
  memories            Memory[]       @relation("UserMemories")
  expensesPaid        Expense[]      @relation("ExpensePayer")
  supportMessages     SupportMessage[] @relation("SupportThread")
  posts               Post[]         @relation("UserPosts")
  likes               Like[]         @relation("UserLikes")
  comments            Comment[]      @relation("UserComments")
  reposts             Repost[]       @relation("UserReposts")
  friendshipsSent     Friendship[]   @relation("FriendRequester")
  friendshipsReceived Friendship[]   @relation("FriendAddressee")
  notifications       Notification[] @relation("UserNotifications")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ─────────────────────────── Social / networking ───────────────────────────
enum SocialTarget {
  TRIP
  POST
}

enum FriendStatus {
  PENDING
  ACCEPTED
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPT
  LIKE
  COMMENT
  REPOST
}

// A user microblog entry ("Новости путешествий").
model Post {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  text      String
  imageUrl  String?
  createdAt DateTime @default(now())
  @@index([createdAt])
}

// Polymorphic like on a TRIP or a POST.
model Like {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)
  targetType SocialTarget
  targetId   String
  createdAt  DateTime     @default(now())
  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

// Polymorphic comment on a TRIP or a POST.
model Comment {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)
  targetType SocialTarget
  targetId   String
  text       String
  createdAt  DateTime     @default(now())
  @@index([targetType, targetId])
}

// A repost of a public trip into the feed.
model Repost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserReposts", fields: [userId], references: [id], onDelete: Cascade)
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, tripId])
}

// Friend request / friendship between two users.
model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  requester   User         @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User         @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
}

// In-app notification (friend requests, likes, comments, reposts).
model Notification {
  id         String           @id @default(cuid())
  userId     String           // recipient
  user       User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  actorId    String?          // who triggered it
  targetType SocialTarget?
  targetId   String?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())
  @@index([userId, read])
}

// Membership of a user in a trip, with a per-trip role.
model TripMember {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      TripMemberRole @default(MEMBER)
  createdAt DateTime @default(now())
  @@unique([tripId, userId])
}

// Append-only audit trail of security-relevant actions.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // e.g. "login", "register", "role.change", "trip.delete"
  objectType String?
  objectId   String?
  ip         String?
  meta       Json?
  createdAt  DateTime @default(now())
}

model SavedTrip {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripId    String
  // Snapshot of a user-customized variant (JSON) — the modular builder output.
  snapshot  Json?
  createdAt DateTime @default(now())
  @@unique([userId, tripId])
}
