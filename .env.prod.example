# Production env for the VPS (docker-compose.prod.yml). Copy to `.env` on the
# server and fill in real values. Never commit the filled-in .env.

# ─── Database: Neon (managed Postgres, free) ──────────────────────────────
# Neon dashboard → your project → Connection string → "Pooled connection".
# Keep sslmode=require. Append Prisma's schema param.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&schema=public

# ─── App ──────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=4000
APP_URL=https://velatrips.ru          # used in email links
JWT_SECRET=                            # generate: openssl rand -hex 32
JWT_EXPIRES=7d

# First super admin (created on boot, idempotent)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# ─── Email (Resend; optional — links log to console if unset) ─────────────
RESEND_API_KEY=
EMAIL_FROM=Vela <no-reply@velatrips.ru>

# ─── AI consultant (Groq; optional) ───────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── File storage (Supabase Storage, S3-compatible; optional) ─────────────
# If unset, uploads fall back to local disk (vela_uploads volume).
# For Supabase set S3_REGION to the project's REAL region (e.g. eu-central-1),
# NOT "auto" — "auto" breaks request signing (uploads fail).
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
